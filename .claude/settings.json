{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(python3 -m http.server *)",
      "Bash(node --check *)",
      "Bash(node_modules/.bin/esbuild *)",
      "Bash(npm run *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git push*)",
      "Bash(git fetch*)",
      "Bash(gh run *)",
      "Bash(gh workflow *)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/session-start.sh"
          },
          {
            "type": "command",
            "command": ".claude/hooks/mcp-http.sh"
          },
          {
            "type": "command",
            "command": ".claude/hooks/orient.sh"
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/subagent-context.sh"
          },
          {
            "type": "command",
            "command": "node .claude/hooks/subagent-route.mjs"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/subagent-verify.sh"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/route-request.mjs"
          },
          {
            "type": "command",
            "command": ".claude/hooks/suggest-workflow.sh"
          },
          {
            "type": "command",
            "command": ".claude/hooks/detect-correction.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/inject-rules.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/guard.mjs"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/check-syntax.sh"
          },
          {
            "type": "command",
            "command": ".claude/hooks/check-data.sh"
          },
          {
            "type": "command",
            "command": ".claude/hooks/gen-docs.sh"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/precompact-handoff.sh"
          }
        ]
      }
    ]
  }
}
