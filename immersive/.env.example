# ── API keys for the immersive splat tooling ──────────────────────────────────
# Paste each key right after the = (no quotes, no spaces). This file is GITIGNORED
# — it never gets committed or deployed. The CLI auto-loads it.

# World Labs (Marble) — PRIMARY splat generator (one call -> .spz world).
#   Get a key + buy credits (min $5; $1 = 1,250 credits):
#   https://platform.worldlabs.ai/api-keys
WLT_API_KEY=<PASTE_FROM_VAULT>

# RunPod — optional GPU fallback (splatfacto pipeline). Settings -> API Keys.
RUNPOD_API_KEY=<PASTE_FROM_VAULT>

# Gemini — optional, only if generating Veo capture via API (paid tier).
#   https://aistudio.google.com
GEMINI_API_KEY=<PASTE_FROM_VAULT>
