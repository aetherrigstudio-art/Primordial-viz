{
  "name": "Primordial-viz",
  "image": "mcr.microsoft.com/devcontainers/javascript-node:22",
  "onCreateCommand": "npm ci --no-audit --no-fund || npm install --no-audit --no-fund",
  "forwardPorts": [8000],
  "portsAttributes": {
    "8000": { "label": "static web app (python3 -m http.server)", "onAutoForward": "silent" }
  },
  "customizations": {
    "vscode": {
      "extensions": ["dbaeumer.vscode-eslint"]
    }
  }
}
